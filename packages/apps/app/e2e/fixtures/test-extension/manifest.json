{
  "manifest_version": 2,
  "name": "SlayZone Test Extension",
  "version": "1.0",
  "description": "E2E test fixture — verifies content script injection and messaging",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  }
}
